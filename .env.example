# MTProxy Docker Environment Variables
# Скопируйте этот файл в .env и настройте под вашу среду

# =============================================================================
# Proxy Configuration
# =============================================================================
MT_PROXY_PORT=8080
MT_HTTPS_PORT=443
MT_PROXY_SECRET=ddcafebabe1234567890abcdef123456
MT_PROXY_WORKERS=4
MT_PROXY_MAX_CONNECTIONS=65535
MT_PROXY_RATE_LIMIT=1000
MT_PROXY_LOG_LEVEL=info

# =============================================================================
# Build Options
# =============================================================================
ENABLE_JEMALLOC=ON
ENABLE_TCMALLOC=OFF
ENABLE_IOURING=OFF
ENABLE_LOW_MEMORY=OFF

# =============================================================================
# Resource Limits
# =============================================================================
CPU_LIMIT=2.0
MEMORY_LIMIT=512M
CPU_RESERVE=0.5
MEMORY_RESERVE=128M

# =============================================================================
# Grafana Configuration
# =============================================================================
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# =============================================================================
# Admin CLI Configuration
# =============================================================================
ADMIN_PORT=8081
ADMIN_AUTH_TOKEN=changeme

# =============================================================================
# Timezone
# =============================================================================
TZ=UTC
